# ===============================
# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.tmp
*.temp
desktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# ===============================
# Application Specific
# ===============================
# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Data files (sensitive)
data/conversation_responses.txt
data/snapshots/
data/*.json
data/*.txt

!data/.gitkeep

# Browser data
browser_data/
*.mhtml

# Temporary files
temp/
tmp/
*.tmp
*.temp

# Cache directories
.cache/
cache/
__pycache__/

# Backup files
*.bak
*.backup
*.old
*.orig

# Secrets and credentials
secrets/
credentials/
*.key
*.pem
*.p12
*.pfx
*.crt
*.cer
*.der

# ===============================
# Playwright
# ===============================
# Playwright browsers (optional - comment out if you want to commit browsers)
# playwright-browsers/
test-results/
playwright-report/

# ===============================
# FastAPI / Uvicorn
# ===============================
# SQLite databases
*.db
*.sqlite
*.sqlite3

# ===============================
# Monitoring & Profiling
# ===============================
# Profiling data
*.prof
*.profile

# Memory dumps
*.hprof

# ===============================
# Docker
# ===============================
# Docker
.dockerignore
Dockerfile.dev
docker-compose.override.yml

# ===============================
# CI/CD
# ===============================
# GitHub Actions
.github/workflows/test.yml.bak

# ===============================
# Documentation
# ===============================
# Sphinx documentation
docs/_build/

# ===============================
# Archive & Compressed files
# ===============================
*.zip
*.tar.gz
*.tar.bz2
*.rar
*.7z

# ===============================
# Custom Project Specific
# ===============================
# Output files
output/
results/
exports/

# Configuration backups
config/*.bak
*.config.bak

# Local development overrides
local_settings.py
settings_local.py

# Performance test results
performance/
benchmarks/
# Local credentials and session data
cs.json
*.cookies.json
